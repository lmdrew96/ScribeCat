{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.scribecat.app",
  "productName": "ScribeCat",
  "version": "1.0.0",

  "build": {
    "beforeDevCommand": "node src-tauri/scripts/prepare-dist.mjs",
    "beforeBuildCommand": "node src-tauri/scripts/prepare-dist.mjs",
    "frontendDist": "./dist"
  },

  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "ScribeCat",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ]
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../icons/scribecat-512.png",
      "../icons/icon32.png"
    ]
  }
}
