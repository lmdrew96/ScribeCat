{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "index.html",
    "distDir": "."
  },
  "package": {
    "productName": "ScribeCat",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
      "identifier": "com.scribecat.app",
      "icon": [
        "icons/scribecat-512.png",
        "icons/icon32.png"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "ScribeCat",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ]
  }
}
