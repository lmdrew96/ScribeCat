{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.scribecat.app",
  "productName": "ScribeCat",
  "version": "1.0.0",

  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1430",
    "frontendDist": "web"
  },

  "app": {
    "windows": [
      {
        "title": "ScribeCat",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ]
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/scribecat-512.png",
      "icons/icon32.png"
    ]
  }
}
