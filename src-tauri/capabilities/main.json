{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Capability for the ScribeCat renderer with the minimal APIs required for audio export and integrations.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "fs:default",
    "fs:allow-download-write-recursive",
    "fs:allow-download-read-recursive",
    "fs:allow-document-write-recursive",
    "fs:allow-document-read-recursive",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "scope": {
        "allow": [
          { "url": "https://api.assemblyai.com/*" },
          { "url": "https://api.airtable.com/*" },
          { "url": "https://hook.us2.make.com/*" },
          { "url": "wss://streaming.assemblyai.com/*" }
        ]
      }
    },
    {
      "identifier": "http:allow-fetch-send",
      "scope": {
        "allow": [
          { "url": "https://api.assemblyai.com/*" },
          { "url": "https://api.airtable.com/*" },
          { "url": "https://hook.us2.make.com/*" },
          { "url": "wss://streaming.assemblyai.com/*" }
        ]
      }
    },
    {
      "identifier": "http:allow-fetch-read-body",
      "scope": {
        "allow": [
          { "url": "https://api.assemblyai.com/*" },
          { "url": "https://api.airtable.com/*" },
          { "url": "https://hook.us2.make.com/*" },
          { "url": "wss://streaming.assemblyai.com/*" }
        ]
      }
    },
    {
      "identifier": "http:allow-fetch-cancel",
      "scope": {
        "allow": [
          { "url": "https://api.assemblyai.com/*" },
          { "url": "https://api.airtable.com/*" },
          { "url": "https://hook.us2.make.com/*" },
          { "url": "wss://streaming.assemblyai.com/*" }
        ]
      }
    },
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text"
  ],
  "remote": {
    "urls": [
      "https://api.assemblyai.com/*",
      "https://api.airtable.com/*",
      "https://hook.us2.make.com/*",
      "wss://streaming.assemblyai.com/*"
    ]
  }
}
