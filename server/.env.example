# Copy this file to server/.env and fill in the secrets locally.
# Request fresh credentials from the service owners whenever a rotation is required.
# Never commit populated .env files back to the repository.

# AssemblyAI API key used to mint temporary streaming tokens for transcription.
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# OpenAI API key for transcript polishing requests.
OPENAI_API_KEY=your-openai-api-key

# Airtable Personal Access Token that authorizes Create/Delete calls.
AIRTABLE_API_KEY=your-airtable-pat

# Airtable base identifier that holds recording metadata.
AIRTABLE_BASE_ID=your-airtable-base-id

# Airtable table name to target (defaults to "Recordings" if left unchanged).
AIRTABLE_TABLE_NAME=Recordings

# Make.com webhook URL for automation triggers (leave blank to disable the integration).
MAKE_WEBHOOK_URL=https://hook.example.com/replace-me
