{
  "manifest_version": 3,
  "name": "ScribeCat Canvas Helper",
  "version": "1.0.2",
  "description": "Scrape Canvas courses and send them to ScribeCat (localhost).",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.instructure.com/*",
    "http://localhost:8787/*",
    "http://127.0.0.1:8787/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ScribeCat Canvas Helper",
    "default_icon": {
      "16": "icons/icon16.svg",
      "24": "icons/icon32.svg",
      "32": "icons/icon32.svg",
      "48": "icons/icon48.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg",
    "512": "icons/icon512.svg"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.instructure.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
