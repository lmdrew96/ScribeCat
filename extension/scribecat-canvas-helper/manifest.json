{
  "manifest_version": 2,
  "name": "ScribeCat Canvas Helper",
  "version": "1.0.2",
  "description": "Scrape Canvas courses and send them to ScribeCat (localhost).",
  "permissions": [
    "storage",
    "https://*.instructure.com/*",
    "http://localhost:8787/*",
    "http://127.0.0.1:8787/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://*.instructure.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "32": "icon32.png",
    "128": "icon128.png"
  }
}
